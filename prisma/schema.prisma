model MinMax {
  id             String   @id @default(cuid())
  shop           String
  variantId      String
  locationId     String
  minLevel       Int      @default(0)
  maxLevel       Int      @default(0)
  casePackSize   Int      @default(1)
  updatedAt      DateTime @updatedAt

  @@unique([shop, variantId, locationId])
}

model Supplier {
  id        String   @id @default(cuid())
  shop      String
  name      String
  createdAt DateTime @default(now())
  skus      SupplierSku[]
}

model Vendor {
  id        String   @id @default(cuid())
  shop      String
  name      String
  createdAt DateTime @default(now())
}

model SupplierSku {
  id            String   @id @default(cuid())
  shop          String
  supplierId    String
  supplier      Supplier @relation(fields: [supplierId], references: [id])
  variantId     String
  supplierCode  String
  cost          Float
  updatedAt     DateTime @updatedAt

  @@unique([supplierId, variantId])
}