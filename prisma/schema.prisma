generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model MinMax {
  id           String   @id @default(cuid())
  shop         String
  variantId    String
  locationId   String
  minLevel     Int      @default(0)
  maxLevel     Int      @default(0)
  casePackSize Int      @default(1)
  updatedAt    DateTime @updatedAt

  @@unique([shop, variantId, locationId])
}

model Supplier {
  id        String              @id @default(cuid())
  shop      String
  name      String
  createdAt DateTime            @default(now())
  skus      SupplierSku[]
  orders    PurchaseOrder[]
}

model Vendor {
  id        String   @id @default(cuid())
  shop      String
  name      String
  createdAt DateTime @default(now())
}

model SupplierSku {
  id           String   @id @default(cuid())
  shop         String
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  variantId    String
  supplierCode String
  cost         Float
  updatedAt    DateTime @updatedAt

  @@unique([supplierId, variantId])
}

model PurchaseOrder {
  id         String              @id @default(cuid())
  shop       String
  poNumber   String
  supplierId String
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  status     String              @default("draft")
  mode       String              @default("minmax")
  locationId String              @default("")
  notes      String?
  orderedAt  DateTime?
  receivedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  items      PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variantId       String
  productTitle    String
  variantTitle    String
  sku             String
  qtyOrdered      Int
  qtyCost         Float
  updatedAt       DateTime      @updatedAt
}