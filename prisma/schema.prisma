generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model MinMax {
  id           String   @id @default(cuid())
  shop         String
  variantId    String
  locationId   String
  minLevel     Int      @default(0)
  maxLevel     Int      @default(0)
  casePackSize Int      @default(1)
  updatedAt    DateTime @updatedAt

  @@unique([shop, variantId, locationId])
}

model Supplier {
  id              String           @id @default(cuid())
  shop            String
  name            String
  createdAt       DateTime         @default(now())
  skus            SupplierSku[]
  orders          PurchaseOrder[]
  vendorSuppliers VendorSupplier[]
}

model Vendor {
  id        String   @id @default(cuid())
  shop      String
  name      String
  createdAt DateTime @default(now())
}

model VendorSupplier {
  id         String   @id @default(cuid())
  shop       String
  vendorName String
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  isPrimary  Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([shop, vendorName, supplierId])
}

model SupplierSku {
  id           String   @id @default(cuid())
  shop         String
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  variantId    String
  supplierCode String
  vendorName   String   @default("")
  cost         Float
  updatedAt    DateTime @updatedAt

  @@unique([supplierId, variantId, vendorName])
}

model PurchaseOrder {
  id         String              @id @default(cuid())
  shop       String
  poNumber   String
  supplierId String
  supplier   Supplier            @relation(fields: [supplierId], references: [id])
  status     String              @default("draft")
  mode       String              @default("minmax")
  locationId String              @default("")
  notes      String?
  orderedAt  DateTime?
  receivedAt DateTime?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  items      PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  variantId       String
  productTitle    String
  variantTitle    String
  sku             String
  supplierCode    String        @default("")
  qtyOrdered      Int
  qtyCost         Float
  updatedAt       DateTime      @updatedAt
}

model TransferTemplate {
  id             String                   @id @default(cuid())
  shop           String
  name           String
  type           String                   @default("simple")
  fromLocationId String
  toLocationId   String
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  vendors        TransferTemplateVendor[]
  transfers      Transfer[]
}

model TransferTemplateVendor {
  id         String           @id @default(cuid())
  templateId String
  template   TransferTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  vendor     String
}

model Transfer {
  id             String            @id @default(cuid())
  shop           String
  transferNumber String
  templateId     String?
  template       TransferTemplate? @relation(fields: [templateId], references: [id])
  fromLocationId String
  toLocationId   String
  status         String            @default("draft")
  notes          String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  items          TransferItem[]
}

mmodel TransferItem {
  id           String   @id @default(cuid())
  transferId   String
  transfer     Transfer @relation(fields: [transferId], references: [id], onDelete: Cascade)
  variantId    String
  productTitle String
  variantTitle String   @default("")
  vendor       String   @default("")
  sku          String   @default("")
  qty          Int
  srcOnHand    Int      @default(0)   // ADD THIS
  destOnHand   Int      @default(0)   // ADD THIS
  srcMin       Int      @default(0)   // ADD THIS
  destNeed     Int      @default(0)   // ADD THIS
  createdAt    DateTime @default(now())
  updatedAt    DateTime
}

model SnapshotCache {
  id           Int      @id @default(autoincrement())
  cacheKey     String   @unique
  rows         Json
  lowCount     Int      @default(0)
  avgST        Int?
  totalUnits   Int      @default(0)
  productTypes Json     @default("[]")
  createdAt    DateTime @default(now())
}

model Stocktake {
  id           String          @id @default(cuid())
  shop         String
  locationId   String
  locationName String
  vendorFilter String?
  typeFilter   String?
  status       String          @default("in_progress")
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  lines        StocktakeLine[]
}

model StocktakeLine {
  id              String    @id @default(cuid())
  stocktakeId     String
  stocktake       Stocktake @relation(fields: [stocktakeId], references: [id], onDelete: Cascade)
  variantId       String
  inventoryItemId String?
  productTitle    String
  variantTitle    String    @default("")
  vendor          String?
  productType     String?
  sku             String?
  onHand          Int
  counted         Int?
  updatedAt       DateTime  @updatedAt
}