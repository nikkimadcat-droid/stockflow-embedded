import dotenv from "dotenv";
dotenv.config({ path: "./app/.env" });

import fs from "fs";
const { default: prisma } = await import("../app/db.server.js");

const SHOP = "8a7777-3c.myshopify.com";
const DATA_FILE = "./scripts/data/stocky-central.json";
const SUPPLIER_NAME = "Central Pet Supply";

function extractVendorName(batch) {
  if (batch.vendor) return batch.vendor.trim();
  const name = (batch.supplier || "").trim();
  if (name.startsWith(SUPPLIER_NAME + " - ")) {
    return name.slice(SUPPLIER_NAME.length + 3).trim();
  }
  return "";
}

async function main() {
  let raw = fs.readFileSync(DATA_FILE, "utf8");
  raw = raw.replace(/[\u0000-\u001F\u007F-\u009F]/g, "");
  const data = JSON.parse(raw);

  // Get offline access token
  const session = await prisma.session.findFirst({
    where: { shop: SHOP, isOnline: false },
  });
  if (!session) throw new Error(`No offline session found for shop ${SHOP}`);
  const accessToken = session.accessToken;

  // Build SKU -> variantId map from Shopify
  console.log("Building SKU map from Shopify...");
  const skuMap = new Map();
  let cursor = null;
  let hasNextPage = true;
  let productCount = 0;

  while (hasNextPage) {
    const query = `
      query ($cursor: String) {
        products(first: 50, after: $cursor) {
          pageInfo { hasNextPage endCursor }
          edges {
            node {
              id
              variants(first: 100) {
                edges {
                  node {
                    id
                    sku
                  }
                }
              }
            }
          }
        }
      }
    `;

    const response = await fetch(
      `https://${SHOP}/admin/api/2025-10/graphql.json`,
      {
        method: "POST",
        headers: {
          "Content-Type": "application/json",
          "X-Shopify-Access-Token": accessToken,
        },
        body: JSON.stringify({ query, variables: { cursor } }),
      }
    );

    const json = await response.json();
    if (!json.data) throw new Error("Shopify API returned no data — check token/scopes.");

    const { edges, pageInfo } = json.data.products;
    for (const { node: product } of edges) {
      productCount++;
      for (const { node: variant } of product.variants.edges) {
        if (variant.sku) skuMap.set(variant.sku, variant.id);
      }
    }

    hasNextPage = pageInfo.hasNextPage;
    cursor = pageInfo.endCursor;
  }

  console.log(`Mapped ${skuMap.size} SKUs across ${productCount} products.`);

  // Find Central Pet Supply supplier
  const supplier = await prisma.supplier.findFirst({
    where: { shop: SHOP, name: SUPPLIER_NAME },
  });
  if (!supplier) throw new Error(`Supplier "${SUPPLIER_NAME}" not found.`);
  console.log(`Found supplier: ${supplier.name} (${supplier.id})`);

  let upserted = 0;
  let skipped = 0;
  let unmatched = 0;

  for (const batch of data) {
    const batchSupplier = (batch.supplier || "").trim();
    if (
      batchSupplier !== SUPPLIER_NAME &&
      !batchSupplier.startsWith(SUPPLIER_NAME + " - ")
    ) {
      continue;
    }

    const vendorName = extractVendorName(batch);
    const rows = batch.rows || [];
    console.log(`\nProcessing: "${batchSupplier}" vendor="${vendorName}" (${rows.length} rows)`);

    for (const row of rows) {
      const sku = row.sku?.trim();
      const supplierCode = row.supplierCode?.trim() || "";
      const cost = parseFloat(row.cost);

      if (!sku || isNaN(cost)) {
        skipped++;
        continue;
      }

      const variantId = skuMap.get(sku);
      if (!variantId) {
        unmatched++;
        continue;
      }

      await prisma.supplierSku.upsert({
        where: {
          supplierId_variantId_vendorName: {
            supplierId: supplier.id,
            variantId,
            vendorName,
          },
        },
        update: { supplierCode, cost },
        create: {
          shop: SHOP,
          supplierId: supplier.id,
          variantId,
          vendorName,
          supplierCode,
          cost,
        },
      });
      upserted++;
    }
  }

  console.log(`\n=== Done ===`);
  console.log(`Upserted:  ${upserted}`);
  console.log(`Skipped:   ${skipped}`);
  console.log(`Unmatched: ${unmatched}`);
}

main()
  .then(() => prisma.$disconnect())
  .catch(async (err) => {
    console.error(err);
    await prisma.$disconnect();
    process.exit(1);
  });